function __apply_bobthefish_scheme --on-event fish_prompt
    if string match -q "Dark" (defaults read -g AppleInterfaceStyle ^/dev/null)
        set -g theme_color_scheme dark
    else
        set -g theme_color_scheme light
    end
end

# Quick project navigation on startup
if status is-interactive; and not set -q PROJECT_SELECTED
    set -g PROJECT_SELECTED 1

    set -l main_menu "NutriKit" "brain" "Downloads" "Projects" "pxlshpr-website" "~"

    echo ""
    set -l choice (printf '%s\n' $main_menu | gum choose --header "Select project to navigate to:" --header.foreground="212")

    if test -n "$choice"
        switch $choice
            case "NutriKit"
                cd "/Users/pxlshpr/Developer/NutriKit"
                echo "→ Switched to NutriKit"

            case "Projects"
                set -l project_names "NutriKit" "Chunes" "Vivara"
                set -l project_choice (printf '%s\n' $project_names | gum choose --header "Select project:" --header.foreground="212")

                switch $project_choice
                    case "NutriKit"
                        set -l nutrikit_options "App" "Website"
                        set -l nutrikit_choice (printf '%s\n' $nutrikit_options | gum choose --header "Select NutriKit project:" --header.foreground="212")

                        if test "$nutrikit_choice" = "App"
                            cd "/Users/pxlshpr/Developer/NutriKit"
                            echo "→ Switched to NutriKit App"
                        else if test "$nutrikit_choice" = "Website"
                            cd "/Users/pxlshpr/Developer/nutrikit-website"
                            echo "→ Switched to NutriKit Website"
                        else
                            cd ~/Developer
                            echo "→ Staying in ~/Developer"
                        end

                    case "Chunes"
                        set -l chunes_options "App" "Website"
                        set -l chunes_choice (printf '%s\n' $chunes_options | gum choose --header "Select Chunes project:" --header.foreground="212")

                        if test "$chunes_choice" = "App"
                            cd "/Users/pxlshpr/Developer/Chunes"
                            echo "→ Switched to Chunes App"
                        else if test "$chunes_choice" = "Website"
                            cd "/Users/pxlshpr/Developer/chunes-website"
                            echo "→ Switched to Chunes Website"
                        else
                            cd ~/Developer
                            echo "→ Staying in ~/Developer"
                        end

                    case "Vivara"
                        cd "/Users/pxlshpr/Developer/Vivara"
                        echo "→ Switched to Vivara"

                    case '*'
                        cd ~/Developer
                        echo "→ Staying in ~/Developer"
                end

            case "pxlshpr-website"
                cd "/Users/pxlshpr/Developer/pxlshpr-website"
                echo "→ Switched to pxlshpr-website"

            case "brain"
                cd ~/brain
                echo "→ Switched to brain"

            case "Downloads"
                cd "/Users/pxlshpr/Downloads"
                echo "→ Switched to Downloads"

            case "~"
                cd ~
                echo "→ Switched to ~"
        end
    else
        cd ~/Developer
        echo "→ Staying in ~/Developer"
    end
    echo ""
else if status is-interactive
    # Only cd to ~/Developer if we didn't just run the project selector
    cd ~/Developer
end

# OFF API Server (Open Food Facts local DuckDB server)
function off
    set -l pid (lsof -ti:3333 2>/dev/null)
    if test -n "$pid"
        echo "⚠️  Server already running (PID: $pid)"
        echo "   Use 'off-stop' to stop it first"
        return 1
    end

    echo "🚀 Starting OFF API server on port 3333..."
    nohup /Volumes/LaCie/off_data/venv/bin/python3 /Users/pxlshpr/Developer/NutriKit/off_prototype/off_api_production.py > /tmp/off-server.log 2>&1 &
    sleep 2

    set -l new_pid (lsof -ti:3333 2>/dev/null)
    if test -n "$new_pid"
        echo "✅ Server started (PID: $new_pid)"
        echo "   Endpoint: http://localhost:3333"
        echo "   Logs: /tmp/off-server.log"
    else
        echo "❌ Failed to start server. Check logs:"
        tail -10 /tmp/off-server.log
    end
end

function off-stop
    set -l pid (lsof -ti:3333 2>/dev/null)
    if test -z "$pid"
        echo "⚠️  No server running on port 3333"
        return 1
    end

    kill -9 $pid 2>/dev/null
    echo "✅ Server stopped (PID: $pid)"
end

function off-status
    set -l pid (lsof -ti:3333 2>/dev/null)
    if test -n "$pid"
        echo "✅ Server running (PID: $pid)"
        echo "   Testing connection..."
        set -l response (curl -s -o /dev/null -w "%{http_code}" http://localhost:3333/stats 2>/dev/null)
        if test "$response" = "200"
            curl -s http://localhost:3333/stats | python3 -m json.tool
        else
            echo "   ⚠️  Server not responding (HTTP $response)"
        end
    else
        echo "❌ Server not running"
    end
end

function cleanup-claude
    set -l current_pid $fish_pid
    echo "Current process PID: $current_pid"
    echo "Looking for old Claude processes..."
    echo ""

    # Get all claude pids
    set -l all_pids (ps aux | grep "claude" | grep -v grep | awk '{print $2}')

    if test -z "$all_pids"
        echo "No Claude processes found!"
        return 0
    end

    set -l to_kill
    for pid in $all_pids
        if test "$pid" != "$current_pid"
            set -a to_kill $pid
        end
    end

    if test -z "$to_kill"
        echo "No old Claude processes to clean up!"
        return 0
    end

    echo "Found "(count $to_kill)" old Claude process(es) to remove:"
    echo ""

    for pid in $to_kill
        set -l info (ps -p $pid -o command= 2>/dev/null)
        echo "  PID $pid: $info"
    end

    echo ""
    read -l -P "Delete these processes? (y/n) " confirm

    if test "$confirm" = "y" -o "$confirm" = "Y"
        for pid in $to_kill
            echo "Killing PID $pid..."
            kill -9 $pid 2>/dev/null && echo "  ✓ Killed" || echo "  ✗ Failed or already gone"
        end
        echo ""
        echo "Cleanup complete!"
    else
        echo "Cancelled."
        return 1
    end
end

export PATH="$HOME/.local/bin:$PATH"
