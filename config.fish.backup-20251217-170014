function vk
        set -l processId (psb | tr -s ' ' | cut -d ' ' -f 2 | head -n 1)
        kill -9 $processId
        echo "Killed vapor server with pid: $processId"
end

function gt
	set -l lastBuild (git describe --tags --abbrev=0 | cut -d'.' -f3)
	
	set -l regex (string join '' 's/^\(.*\)' $lastBuild '$/\1/')
	set -l prefix (git describe --tags --abbrev=0 | sed $regex)
	set -l nextBuild (math $lastBuild + 1)
	set -l nextTag (string join '' $prefix $nextBuild)
	
	git add .
	git commit -a -m "tag increment"
	git push
	git tag $nextTag
	git push --tags
end

function gp
    if test (count $argv) -eq 0
        echo "Usage: gp \"commit message\""
        return 1
    end

    git add .
    git commit -a -m "$argv"
    git push
end

